{
  "repositoryUrl": "https://github.com/hxreborn/playstore-adblock.git",
  "branches": ["main", "master"],
  "tagFormat": "v${version}",
  "plugins": [
    ["@semantic-release/commit-analyzer", {
      "preset": "conventionalcommits",
      "releaseRules": [
        { "type": "security", "release": "patch" },
        { "type": "refactor", "release": "patch" },
        { "scope": "deps", "release": false }
      ]
    }],
    ["@semantic-release/release-notes-generator", {
      "preset": "conventionalcommits",
      "presetConfig": {
        "types": [
          { "type": "feat",     "section": "Features" },
          { "type": "fix",      "section": "Bug Fixes" },
          { "type": "perf",     "section": "Performance Improvements" },
          { "type": "security", "section": "Security" },
          { "type": "refactor", "section": "Refactor" },
          { "type": "revert",   "section": "Reverts" },
          { "type": "test",     "section": "Tests" },
          { "type": "build",    "section": "Build System" },
          { "type": "docs",  "hidden": true },
          { "type": "style", "hidden": true },
          { "type": "ci",    "hidden": true },
          { "type": "chore", "hidden": true }
        ]
      }
    }],
    ["@semantic-release/exec", {
      "prepareCmd": "bash .github/semantic-release-prepare.sh ${nextRelease.version}"
    }],
    ["@semantic-release/git", {
      "assets": ["gradle.properties"],
      "message": "chore(release): ${nextRelease.version} [skip ci]"
    }],
    ["@semantic-release/github", {
      "assets": [
        {
          "path": "playstore-adblock-v*-arm64-v8a.apk",
          "label": "Play Store Adblock v${nextRelease.version} (arm64-v8a)"
        }
      ]
    }]
  ]
}
